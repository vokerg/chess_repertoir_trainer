# Example environment variables for the chess repertoire trainer API
#
# Copy this file to:
#   apps/api/.env
# For the Angular app, expose the WEB_* values in your web build environment.

# Angular frontend API base URL. Use /api with the Angular dev proxy.
WEB_API_BASE_URL=/api
WEB_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key

# API port
PORT=3000

# Request authentication. Use dev-single-user only for local development.
AUTH_MODE=dev-single-user
DEV_SINGLE_USER_ID=1

# Clerk JWT verification settings used when AUTH_MODE=clerk.
CLERK_JWT_ISSUER="https://your-clerk-instance.clerk.accounts.dev"
CLERK_JWKS_URL="https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json"
CLERK_AUTHORIZED_PARTIES="http://localhost:4200"
# CLERK_JWT_AUDIENCE="your-api-audience"

# Neon pooled connection string for the running app
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLED-HOST/neondb?sslmode=require&channel_binding=require"

# Direct Neon connection string for Prisma CLI commands such as migrate/seed
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-DIRECT-HOST/neondb?sslmode=require&channel_binding=require"

# Prisma log level (optional, can be info/debug)
PRISMA_LOG_LEVEL=info

# CORS origin allowed for Angular during local development
CORS_ORIGIN=http://localhost:4200

# Lichess OAuth. The token encryption key must decode to exactly 32 bytes.
# Users must reconnect Lichess after changing OAuth scopes.
LICHESS_OAUTH_CLIENT_ID="chess-repertoire-trainer-local"
LICHESS_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/lichess/callback"
LICHESS_OAUTH_SCOPES="challenge:write"
LICHESS_BOT_CHALLENGE_USERNAMES="maia1,maia5,maia9"
LICHESS_DEFAULT_BOT_CHALLENGE_USERNAME="maia5"
LICHESS_TOKEN_ENCRYPTION_KEY="base64-32-byte-key-here"
WEB_APP_URL="http://localhost:4200"

# Chess.com public API import requests should use a recognizable User-Agent.
# Include a contact URL or email if you deploy this outside local development.
CHESS_COM_USER_AGENT="chess-repertoire-trainer/0.1 (+https://github.com/vokerg/chess_repertoir_trainer)"

# Enables local-only batch Stockfish analysis from visible games in the web UI.
# Disabled by default; Stockfish path/depth/timeout use code defaults.
LOCAL_BATCH_STOCKFISH_ANALYSIS_ENABLED=false
