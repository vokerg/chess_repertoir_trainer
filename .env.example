# Example environment variables for the chess repertoire trainer

# API port
PORT=3000

# SQLite database location for Prisma
# Note: This path is resolved relative to the Prisma schema file
# (apps/api/prisma/schema.prisma)
DATABASE_URL="file:../../../data/dev.db"

# Prisma log level (optional, can be info/debug)
PRISMA_LOG_LEVEL=info

# CORS origin allowed for Angular during local development
CORS_ORIGIN=http://localhost:4200