{
  "name": "blunder-patterns-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "migrate": "ts-node --esm src/migrate.ts",
    "pipeline": "ts-node --esm src/pipeline.ts",
    "check": "npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "chess.js": "^1.0.0",
    "dotenv