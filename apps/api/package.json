{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "(cd ../.. && npm run build --workspace=packages/chess-domain) && prisma migrate deploy && prisma generate && ts-node-dev --respawn --transpile-only src/main.ts",
    "dev:worker": "prisma migrate deploy && prisma generate && ts-node-dev --respawn --transpile-only src/analysis-worker.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/analysis-worker.js",
    "db:migrate": "prisma migrate deploy && prisma generate",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && prisma generate && npm run db:seed",
    "prisma:studio": "prisma studio",
    "test": "node -e \"console.log('No api tests yet')\""
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^5.6.0",
    "chess-domain": "file:../../packages/chess-domain",
    "chess.js": "^1.0.0",
    "dotenv": "^16.3.1",
    "fastify": "^5.8.5",
    "prisma": "^5.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.7"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
