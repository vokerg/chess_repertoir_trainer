{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "predev": "npm --prefix ../.. run build:domain && npm --prefix ../.. run build:contracts && prisma generate --schema prisma/schema.prisma",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prebuild": "npm --prefix ../.. run build:domain && npm --prefix ../.. run build:contracts && prisma generate --schema prisma/schema.prisma",
    "build": "tsc -p tsconfig.json",
    "prelint": "npm --prefix ../.. run build:domain && npm --prefix ../.. run build:contracts && prisma generate --schema prisma/schema.prisma",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prestart": "prisma generate --schema prisma/schema.prisma",
    "start": "node dist/main.js",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma && prisma generate --schema prisma/schema.prisma",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:backfill-position-keys": "ts-node --transpile-only src/scripts/backfill-position-keys.ts",
    "db:backfill-game-openings": "ts-node --transpile-only src/scripts/backfill-missing-game-openings.ts",
    "db:cleanup-position-analysis-lines": "ts-node --transpile-only src/scripts/cleanup-position-analysis-lines.ts",
    "db:rewrite-position-keys-128": "ts-node --transpile-only src/scripts/rewrite-position-keys-to-128-bit.ts",
    "opening-book:update": "ts-node --transpile-only src/scripts/update-opening-book.ts",
    "tags:refresh-analysed": "ts-node --transpile-only src/scripts/refresh-analysed-game-tags.ts",
    "db:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force --schema prisma/schema.prisma && prisma generate --schema prisma/schema.prisma && npm run db:seed",
    "prisma:studio": "prisma studio",
    "test": "npm run build && node test/run-all.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@prisma/client": "^6.19.3",
    "@chess-trainer/contracts": "file:../../packages/contracts",
    "chess-domain": "file:../../packages/chess-domain",
    "chess.js": "^1.0.0",
    "dotenv": "^16.3.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^7.0.0",
    "jose": "^6.2.3",
    "prisma": "^6.19.3",
    "stockfish": "^18.0.7",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.7"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
