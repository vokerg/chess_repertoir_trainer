// Prisma schema for the chess repertoire trainer API. This defines
// entities for courses, chapters, lines, move nodes, training sessions
// and attempts. It also stores imported games from external chess accounts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AppUser {
  id               Int               @id @default(autoincrement())
  displayName      String?
  externalAccounts ExternalAccount[]
  importedGames    ImportedGame[]
  importRuns       ImportRun[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ExternalAccount {
  id                  Int            @id @default(autoincrement())
  userId              Int
  user                AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider            String
  username            String
  displayName         String?
  providerUserId      String?
  isActive            Boolean        @default(true)
  lastSyncAt          DateTime?
  syncCursorTime      DateTime?
  lastSyncRunId       Int?
  importedGames       ImportedGame[]
  importRuns          ImportRun[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([userId, provider, username])
  @@index([userId])
  @@index([provider, username])
}

model ImportedGame {
  id                    Int             @id @default(autoincrement())
  userId                Int
  user                  AppUser         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             Int
  account               ExternalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider              String
  providerGameId        String
  providerUrl           String?
  pgn                   String?
  rawJson               Json?
  rated                 Boolean?
  variant               String?
  speedCategory         String?
  timeControlRaw        String?
  timeControlInitial    Int?
  timeControlIncrement  Int?
  startedAt             DateTime?
  endedAt               DateTime?
  whiteUsername         String?
  blackUsername         String?
  whiteRating           Int?
  blackRating           Int?
  userColor             String?
  opponentUsername      String?
  result                String?
  resultForUser         String?
  status                String?
  openingName           String?
  openingEco            String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([accountId, providerGameId])
  @@index([userId, endedAt])
  @@index([accountId, endedAt])
  @@index([provider, providerGameId])
}

model ImportRun {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       Int
  account         ExternalAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider        String
  status          String
  syncSince       DateTime?
  syncUntil       DateTime?
  gamesSeen       Int              @default(0)
  gamesImported   Int              @default(0)
  gamesUpdated    Int              @default(0)
  gamesSkipped    Int              @default(0)
  gamesFailed     Int              @default(0)
  error           String?
  startedAt       DateTime         @default(now())
  completedAt     DateTime?

  @@index([accountId, startedAt])
  @@index([userId, startedAt])
}

model Course {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  chapters    Chapter[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Chapter {
  id          Int      @id @default(autoincrement())
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  lines       Line[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Line {
  id              Int      @id @default(autoincrement())
  chapterId       Int
  chapter         Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  name            String
  sideToTrain     String
  startingFen     String
  tags            String?
  notes           String?
  passedCount     Int      @default(0)
  failedCount     Int      @default(0)
  totalAttempts   Int      @default(0)
  lastTrainedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  moves           MoveNode[]
  sessions        TrainingSession[]
}

model MoveNode {
  id              Int      @id @default(autoincrement())
  lineId          Int
  parentId        Int?
  line            Line     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  parent          MoveNode?@relation("MoveNodeToMoveNode", fields: [parentId], references: [id], onDelete: Cascade)
  children        MoveNode[] @relation("MoveNodeToMoveNode")
  trainingAttempts TrainingAttemptMove[]
  plyNumber       Int
  fenBefore       String
  fenAfter        String
  moveUci         String
  moveSan         String
  moveNumber      Int
  colorToMoveBefore String
  side            String
  isUserMove      Boolean
  isCorrectUserMove Boolean
  comment         String?
  annotation      String?
  branchLabel     String?
  branchWeight    Float?
  sortOrder       Int      @default(0)
  timesSeen       Int      @default(0)
  correctCount    Int      @default(0)
  incorrectCount  Int      @default(0)
  currentStreak   Int      @default(0)
  lastSeenAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TrainingSession {
  id                 Int      @id @default(autoincrement())
  lineId             Int
  line               Line     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  attempts           TrainingAttemptMove[]
  startedAt          DateTime @default(now())
  completedAt        DateTime?
  result             String
  mistakesCount      Int      @default(0)
  totalExpectedMoves Int      @default(0)
  correctMoves       Int      @default(0)
  accuracy           Float?
}

model TrainingAttemptMove {
  id             Int      @id @default(autoincrement())
  sessionId      Int
  session        TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  moveNodeId     Int?
  moveNode       MoveNode? @relation(fields: [moveNodeId], references: [id], onDelete: Cascade)
  fenBefore      String
  expectedMoveUci String?
  playedMoveUci  String?
  wasCorrect     Boolean
  createdAt      DateTime @default(now())
}