// Prisma schema for the chess repertoire trainer API. This defines
// entities for courses, chapters, lines, move nodes, training sessions
// and attempts. It also stores imported games from external chess accounts
// and lightweight client-computed position analysis.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AppUser {
  id               Int               @id @default(autoincrement())
  displayName      String?
  authProvider     String?
  authSubject      String?
  email            String?
  externalAccounts ExternalAccount[]
  lichessConnection LichessConnection?
  importedGames    ImportedGame[]
  importRuns       ImportRun[]
  tacticalDetectionRuns           TacticalDetectionRun[]
  tacticalDetections              TacticalDetection[]
  tacticalDetectionProcessedGames TacticalDetectionProcessedGame[]
  tacticalDetectionFeedbacks      TacticalDetectionFeedback[]
  scenarioTrainingSessions        ScenarioTrainingSession[]
  courses          Course[]
  trainingSessions TrainingSession[]
  trainingSublineAttempts TrainingSublineAttempt[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([authProvider, authSubject])
}

model ExternalAccount {
  id                  Int            @id @default(autoincrement())
  userId              Int
  user                AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider            String
  username            String
  displayName         String?
  providerUserId      String?
  isActive            Boolean        @default(true)
  lastSyncAt          DateTime?
  syncCursorTime      DateTime?
  lastSyncRunId       Int?
  importedGames       ImportedGame[]
  importRuns          ImportRun[]
  ratingStats         AccountRatingStats?
  lichessConnections  LichessConnection[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([userId, provider, username])
  @@index([userId])
  @@index([provider, username])
}

model LichessConnection {
  id                    Int              @id @default(autoincrement())
  userId                Int              @unique
  user                  AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalAccountId     Int?
  externalAccount       ExternalAccount? @relation(fields: [externalAccountId], references: [id], onDelete: SetNull)
  lichessUserId         String
  username              String
  scopes                String[]
  accessTokenCiphertext String
  accessTokenIv         String
  accessTokenAuthTag    String
  expiresAt             DateTime?
  connectedAt           DateTime         @default(now())
  revokedAt             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([lichessUserId])
  @@index([username])
}

model OAuthLoginState {
  id            Int      @id @default(autoincrement())
  userId        Int
  provider      String
  state         String   @unique
  codeVerifier  String
  redirectAfter String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([userId, provider])
  @@index([expiresAt])
}

model AccountRatingStats {
  accountId  Int             @id
  account    ExternalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  computedAt DateTime        @default(now())
  gamesCount Int             @default(0)
  data       Json
}

model ImportedGame {
  id                    Int                @id @default(autoincrement())
  userId                Int
  user                  AppUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             Int
  account               ExternalAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider              String
  providerGameId        String
  providerUrl           String?
  pgn                   String?
  rated                 Boolean?
  variant               String?
  speedCategory         String?
  timeControlRaw        String?
  timeControlInitial    Int?
  timeControlIncrement  Int?
  startedAt             DateTime?
  endedAt               DateTime?
  whiteUsername         String?
  blackUsername         String?
  whiteRating           Int?
  blackRating           Int?
  userColor             String?
  opponentUsername      String?
  result                String?
  resultForUser         String?
  status                String?
  openingName           String?
  openingEco            String?
  plyIndexedAt          DateTime?
  plyIndexError         String?
  tagCodes              Int[]              @default([])
  latestAnalysisRunId   Int?
  latestAnalysisStatus  String?
  latestAnalysisCreatedAt DateTime?
  latestAnalysisCompletedAt DateTime?
  latestWhiteAccuracy   Float?
  latestBlackAccuracy   Float?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  analysisRuns          GameAnalysisRun[]
  plies                 ImportedGamePly[]
  tacticalDetections              TacticalDetection[]
  tacticalDetectionProcessedGames TacticalDetectionProcessedGame[]
  tacticalDetectionFeedbacks      TacticalDetectionFeedback[]
  scenarioTrainingSessions        ScenarioTrainingSession[]

  @@unique([accountId, providerGameId])
  @@index([userId, endedAt])
  @@index([accountId, endedAt])
  @@index([userId, latestAnalysisStatus, endedAt])
}

model TacticalDetectionRun {
  id             Int                              @id @default(autoincrement())
  userId         Int
  user           AppUser                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  from           DateTime
  to             DateTime
  force          Boolean                          @default(false)
  thresholds     Json
  thresholdsHash String
  gamesScanned   Int                              @default(0)
  detectionsMade Int                              @default(0)
  startedAt      DateTime                         @default(now())
  completedAt    DateTime?
  error          String?
  detections     TacticalDetection[]
  processedGames TacticalDetectionProcessedGame[]

  @@index([userId, startedAt])
  @@index([userId, thresholdsHash])
}

model TacticalDetection {
  id                     Int                  @id @default(autoincrement())
  runId                  Int
  run                    TacticalDetectionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId                 Int
  user                   AppUser              @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedGameId         Int
  importedGame           ImportedGame         @relation(fields: [importedGameId], references: [id], onDelete: Cascade)
  kind                   String
  thresholdsHash         String               @db.VarChar(64)
  detectionVersion       Int                  @default(2)
  triggerPlyNumber       Int                  @db.SmallInt
  userReplyPlyNumber     Int?                 @db.SmallInt
  moveUci                String               @db.VarChar(5)
  bestMoveUci            String?              @db.VarChar(5)
  evalBeforeUserCp       Int?
  evalAfterTriggerUserCp Int?
  evalAfterReplyUserCp   Int?
  swingCp                Int?
  createdAt              DateTime             @default(now())
  scenarioTrainingSessions ScenarioTrainingSession[]

  @@unique([userId, importedGameId, kind, triggerPlyNumber, thresholdsHash, detectionVersion], map: "TacticalDetection_scope_key")
  @@index([userId, kind, createdAt])
  @@index([userId, importedGameId])
  @@index([userId, thresholdsHash, detectionVersion])
}

model TacticalDetectionProcessedGame {
  userId         Int
  user           AppUser              @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedGameId Int
  importedGame   ImportedGame         @relation(fields: [importedGameId], references: [id], onDelete: Cascade)
  thresholdsHash String
  runId          Int
  run            TacticalDetectionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  scannedAt      DateTime             @default(now())

  @@id([userId, importedGameId, thresholdsHash])
  @@index([userId, scannedAt])
  @@index([runId])
}

model TacticalDetectionFeedback {
  id Int @id @default(autoincrement())

  userId Int
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  importedGameId Int
  importedGame ImportedGame @relation(fields: [importedGameId], references: [id], onDelete: Cascade)

  kind String
  triggerPlyNumber Int @db.SmallInt
  status String @default("DISLIKED")
  reason String?
  sourceSessionId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, importedGameId, kind, triggerPlyNumber])
  @@index([userId, status, updatedAt])
  @@index([userId, importedGameId])
}

model GameTagDefinition {
  code Int    @id
  name String @unique @db.VarChar(80)
}

model Position {
  id            Int               @id @default(autoincrement())
  positionKey   Bytes             @unique @db.ByteA
  normalizedFen String            @db.VarChar(120)

  plies         ImportedGamePly[]
  analysis      PositionAnalysis?

  @@map("ImportedGamePosition")
}

model ImportedGamePly {
  importedGameId Int
  importedGame   ImportedGame @relation(fields: [importedGameId], references: [id], onDelete: Cascade)

  positionId     Int
  position       Position     @relation(fields: [positionId], references: [id])

  plyNumber      Int    @db.SmallInt
  moveUci        String @db.VarChar(5)

  scoreLossCp        Int? @db.SmallInt
  classificationCode Int? @db.SmallInt

  @@id([importedGameId, plyNumber])
  @@index([positionId, moveUci, importedGameId, plyNumber])
}

model ImportRun {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       Int
  account         ExternalAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider        String
  status          String
  syncSince       DateTime?
  syncUntil       DateTime?
  gamesSeen       Int              @default(0)
  gamesImported   Int              @default(0)
  gamesUpdated    Int              @default(0)
  gamesSkipped    Int              @default(0)
  gamesFailed     Int              @default(0)
  error           String?
  startedAt       DateTime         @default(now())
  completedAt     DateTime?

  @@index([accountId, startedAt])
  @@index([userId, startedAt])
}

model PositionAnalysis {
  id               Int      @id @default(autoincrement())
  positionId       Int      @unique
  position         Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  bestMoveUci      String?  @db.VarChar(5)
  bestScoreCpWhite Int?     @db.SmallInt
  bestMateWhite    Int?     @db.SmallInt
  lines            Json?
}

model GameAnalysisRun {
  id                        Int          @id @default(autoincrement())
  importedGameId            Int
  importedGame              ImportedGame @relation(fields: [importedGameId], references: [id], onDelete: Cascade)
  status                    String
  positionsTotal            Int          @default(0)
  positionsDone             Int          @default(0)
  summary                   Json?
  accuracyVersion           String?
  whiteAccuracy             Float?
  blackAccuracy             Float?
  whiteAverageCentipawnLoss Float?
  blackAverageCentipawnLoss Float?
  whiteMovesAnalyzed        Int          @default(0)
  blackMovesAnalyzed        Int          @default(0)
  error                     String?
  startedAt                 DateTime     @default(now())
  completedAt               DateTime?
  createdAt                 DateTime     @default(now())

  @@index([importedGameId, createdAt])
  @@index([status])
}

model ScenarioTrainingSession {
  id Int @id @default(autoincrement())

  userId Int
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  scenarioType String
  sourceType String
  sourceId Int

  tacticalDetectionId Int?
  tacticalDetection TacticalDetection? @relation(fields: [tacticalDetectionId], references: [id], onDelete: SetNull)

  importedGameId Int?
  importedGame ImportedGame? @relation(fields: [importedGameId], references: [id], onDelete: SetNull)

  userColor String
  opponentUsername String?

  whiteUsername String?
  blackUsername String?
  resultForUser String?
  gameResult String?
  openingEco String?
  openingName String?
  endedAt DateTime?
  providerUrl String?

  previousFen String?
  startFen String
  challengePlyNumber Int

  triggerMoveUci String?
  triggerMoveSan String?
  originalUserMoveUci String?
  originalUserMoveSan String?
  referenceBestMoveUci String?

  contextPlies Json

  baselineUserEvalCp Int?
  passToleranceCp Int @default(100)

  status String @default("IN_PROGRESS")
  startedAt DateTime @default(now())
  completedAt DateTime?

  attempts ScenarioTrainingAttempt[]

  @@index([userId, scenarioType, startedAt])
  @@index([userId, sourceType, sourceId])
  @@index([userId, tacticalDetectionId])
}

model ScenarioTrainingAttempt {
  id Int @id @default(autoincrement())

  sessionId Int
  session ScenarioTrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  attemptNumber Int

  fenBefore String
  playedMoveUci String
  playedMoveSan String?
  fenAfter String

  baselineUserEvalCp Int?
  afterUserEvalCp Int?
  deltaCp Int?

  passed Boolean

  engineSource String
  engineName String?
  engineDepth Int
  engineMultipv Int @default(1)
  rawEngineJson Json?

  createdAt DateTime @default(now())

  @@index([sessionId, attemptNumber])
}

model Course {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  chapters    Chapter[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model Chapter {
  id          Int      @id @default(autoincrement())
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  lines       Line[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Line {
  id                  Int      @id @default(autoincrement())
  chapterId           Int
  chapter             Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  name                String
  sideToTrain         String
  startingFen         String
  tags                String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  moves               MoveNode[]
  sessions            TrainingSession[]
  sublineAttempts     TrainingSublineAttempt[]

  @@index([chapterId])
}

model MoveNode {
  id              Int      @id @default(autoincrement())
  lineId          Int
  parentId        Int?
  line            Line     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  parent          MoveNode?@relation("MoveNodeToMoveNode", fields: [parentId], references: [id], onDelete: Cascade)
  children        MoveNode[] @relation("MoveNodeToMoveNode")
  trainingAttempts TrainingAttemptMove[]
  plyNumber       Int
  fenBefore       String
  fenBeforeNormalized String?  @db.VarChar(120)
  fenAfter        String
  moveUci         String
  moveSan         String
  moveNumber      Int
  colorToMoveBefore String
  side            String
  isUserMove      Boolean
  isCorrectUserMove Boolean
  comment         String?
  annotation      String?
  branchLabel     String?
  branchWeight    Float?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([lineId, parentId])
  @@index([lineId, parentId, moveUci])
  @@index([fenBeforeNormalized])
}

model TrainingSession {
  id                 Int      @id @default(autoincrement())
  userId             Int
  user               AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineId             Int
  line               Line     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  attempts           TrainingAttemptMove[]
  startedAt          DateTime @default(now())
  completedAt        DateTime?
  result             String
  mistakesCount      Int      @default(0)
  totalExpectedMoves Int      @default(0)
  correctMoves       Int      @default(0)
  accuracy           Float?
  sublineAttempt     TrainingSublineAttempt?

  @@index([userId, startedAt])
  @@index([userId, result])
  @@index([userId, lineId])
}

model TrainingSublineAttempt {
  id                 Int       @id @default(autoincrement())

  userId             Int
  user               AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lineId             Int
  line               Line      @relation(fields: [lineId], references: [id], onDelete: Cascade)

  trainingSessionId Int?      @unique
  trainingSession   TrainingSession? @relation(fields: [trainingSessionId], references: [id], onDelete: SetNull)

  sublineHash        String    @db.VarChar(64)
  sublineKeyVersion  Int       @default(1)

  movesJson          Json
  moveText           String?

  trainingMode       String
  result             String

  passed             Boolean?
  mistakesCount      Int       @default(0)
  totalExpectedMoves Int       @default(0)
  correctMoves       Int       @default(0)
  accuracy           Float?

  startedAt          DateTime  @default(now())
  completedAt        DateTime?

  @@index([userId, lineId, startedAt])
  @@index([userId, sublineHash, startedAt])
  @@index([userId, lineId, sublineHash, startedAt])
  @@index([userId, result])
}

model TrainingAttemptMove {
  id             Int      @id @default(autoincrement())
  sessionId      Int
  session        TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  moveNodeId     Int?
  moveNode       MoveNode? @relation(fields: [moveNodeId], references: [id], onDelete: Cascade)
  fenBefore      String
  expectedMoveUci String?
  playedMoveUci  String?
  wasCorrect     Boolean
  createdAt      DateTime @default(now())
}
