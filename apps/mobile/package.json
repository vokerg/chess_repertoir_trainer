{
  "name": "@chess-trainer/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "prestart": "npm --prefix ../.. run build:domain && npm --prefix ../.. run build:contracts",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "npm --prefix ../.. run build:domain && npm --prefix ../.. run build:contracts",
    "build": "expo export --platform web --output-dir dist",
    "pretest": "npm --prefix ../.. run build:domain && npm --prefix ../.. run build:contracts",
    "test": "vitest run",
    "prelint": "npm --prefix ../.. run build:domain && npm --prefix ../.. run build:contracts",
    "lint": "tsc --noEmit",
    "expo:check": "expo install --check",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@chess-trainer/contracts": "file:../../packages/contracts",
    "@clerk/expo": "3.7.4",
    "@expo/metro-runtime": "~6.1.2",
    "@lichess-org/chessground": "10.1.0",
    "babel-preset-expo": "~54.0.10",
    "chess-domain": "file:../../packages/chess-domain",
    "chess.js": "1.0.0",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.10",
    "expo-crypto": "~15.0.9",
    "expo-linking": "~8.0.11",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.22",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.0.0"
  }
}
