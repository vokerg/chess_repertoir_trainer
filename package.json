{
  "name": "chess-repertoire-trainer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api",
    "apps/mobile",
    "packages/chess-domain",
    "packages/contracts"
  ],
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "backup:courses": "ts-node --project scripts/tsconfig.json scripts/course-backup/backup-courses.ts",
    "dev": "npm run build:domain && npm run build:contracts && concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build": "npm run build:domain && npm run build:contracts && npm run build:api && npm run build:web && npm run build:mobile",
    "build:domain": "npm run build --workspace=packages/chess-domain",
    "build:contracts": "npm run build --workspace=packages/contracts",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:mobile": "npm run build --workspace=apps/mobile",
    "test": "npm run test --workspace=packages/chess-domain && npm run test:contracts && npm run test --workspace=apps/api && npm run test --workspace=apps/web && npm run test:mobile",
    "test:contracts": "npm run test --workspace=packages/contracts",
    "test:mobile": "npm run test --workspace=apps/mobile",
    "lint": "npm run lint --workspace=apps/api && npm run lint --workspace=apps/web && npm run lint:mobile",
    "lint:mobile": "npm run lint --workspace=apps/mobile",
    "expo:check": "npm run expo:check --workspace=apps/mobile",
    "check:architecture": "node scripts/check-architecture-guardrails.mjs && node scripts/check-mobile-dependency-resolution.mjs && node scripts/check-mobile-router-entry.mjs",
    "format": "npm run format --workspaces",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:reset": "npm run db:reset --workspace=apps/api",
    "prisma:studio": "npm run prisma:studio --workspace=apps/api"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/compiler-cli": "^21.2.17",
    "chokidar": "^5.0.0",
    "concurrently": "^8.2.0",
    "prisma": "^6.19.3",
    "readdirp": "^5.0.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@prisma/client": "^6.19.3",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "hono": "4.12.26",
    "jayson": {
      "uuid": "11.1.1",
      "ws": "8.21.0"
    },
    "js-yaml": "4.2.0",
    "piscina": "5.2.0",
    "react-native": "0.81.5",
    "sockjs": {
      "uuid": "11.1.1"
    },
    "tar": "7.5.16",
    "undici": "7.28.0",
    "viem": {
      "ws": "8.21.0"
    },
    "vite": "7.3.5",
    "webpack-dev-server": "5.2.5",
    "ws": "8.21.0"
  }
}
