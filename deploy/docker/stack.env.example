# Copy this file to stack.env and replace every placeholder before starting the stack.
# stack.env is read only when Compose creates the API and worker containers. It is
# never copied into the image and must not be committed.

NODE_ENV=production
PORT=3000

# Authentication. Use clerk for a shared or internet-accessible deployment.
AUTH_MODE=clerk
DEV_SINGLE_USER_ID=1
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUTHORIZED_PARTIES=http://localhost:8080
# CLERK_JWT_AUDIENCE=your-api-audience

# Neon pooled runtime URL and direct migration URL. Replace both placeholders.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-POOLED-HOST/neondb?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://USER:PASSWORD@YOUR-DIRECT-HOST/neondb?sslmode=require&channel_binding=require
PRISMA_LOG_LEVEL=info

# Browser-facing origins. Change these to the VM's public HTTPS origin in production.
CORS_ORIGIN=http://localhost:8080
WEB_APP_URL=http://localhost:8080

# Lichess OAuth. Generate a unique base64-encoded 32-byte encryption key.
LICHESS_OAUTH_CLIENT_ID=replace-with-lichess-client-id
LICHESS_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/lichess/callback
LICHESS_OAUTH_SCOPES=challenge:write
LICHESS_BOT_CHALLENGE_USERNAMES=maia1,maia5,maia9
LICHESS_DEFAULT_BOT_CHALLENGE_USERNAME=maia5
LICHESS_TOKEN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# Persistent worker timing. Stale-after must be more than twice heartbeat interval.
JOB_WORKER_POLL_INTERVAL_MS=1000
JOB_WORKER_HEARTBEAT_INTERVAL_MS=30000
JOB_WORKER_STALE_AFTER_MS=900000
JOB_WORKER_STALE_RECOVERY_INTERVAL_MS=60000
JOB_WORKER_TERMINAL_RETENTION_DAYS=30
JOB_WORKER_SLICE_SIZE=25
JOB_WORKER_SHUTDOWN_TIMEOUT_MS=30000

# The image intentionally contains no native Stockfish executable.
LOCAL_BATCH_STOCKFISH_ANALYSIS_ENABLED=true
STOCKFISH_ENGINE=wasm
STOCKFISH_ANALYSIS_DEPTH=12
STOCKFISH_ANALYSIS_TIMEOUT_MS=15000

# Optional API features. AI is disabled by default and belongs only on the API runtime.
AI_WIDGETS_ENABLED=false
AI_GAME_REVIEW_ENABLED=false
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=replace-with-deepseek-api-key
LLM_TIMEOUT_MS=120000
LLM_MAX_RETRIES=1
LLM_THINKING_MODE=disabled
LLM_REASONING_EFFORT=
LLM_DEBUG_LOGGING=false

MCP_ENABLED=false
MCP_AUTH_MODE=token
MCP_BEARER_TOKEN=replace-with-random-bearer-token
CHESS_COM_USER_AGENT=chess-repertoire-trainer
CHESSVISION_FEN2IMAGE_BASE_URL=https://chessvision.ai
PERFORMANCE_DEBUG=false
