{
  "name": "chess-domain",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./training": {
      "types": "./dist/training/index.d.ts",
      "default": "./dist/training/index.js"
    },
    "./sublines": {
      "types": "./dist/sublines.d.ts",
      "default": "./dist/sublines.js"
    },
    "./position": {
      "types": "./dist/position.d.ts",
      "default": "./dist/position.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "chess.js": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.7"
  }
}
