      "types": "./dist/training/index.d.ts",
      "default": "./dist/training/index.js"
    },
    "./mobile-sync": {
      "types": "./dist/mobile-sync/index.d.ts",
      "default": "./dist/mobile-sync/index.js"
    },
    "./lab": {
      "types": "./dist/lab/index.d.ts",
      "default": "./dist/lab/index.js"
    },
    "./opening-struggles": {
      "types": "./dist/opening-struggles/index.d.ts",
